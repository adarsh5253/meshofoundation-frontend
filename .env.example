# Copy this file to .env.local (which is gitignored by Vite by default) and adjust.

# URL of the Mesho Foundation backend API.
# When running the backend locally on port 5000, leave this as-is.
VITE_API_URL=http://localhost:5000

# Razorpay PUBLIC key id (the one starting with rzp_test_ or rzp_live_).
# NEVER set the secret here — that stays on the backend only.
# This is optional — the backend also returns key_id in the create-order
# response, so the frontend can fall back to that if this isn't set.
VITE_RAZORPAY_KEY_ID=rzp_test_SinOSgkven1ITD
